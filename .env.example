# Database Configuration
POSTGRES_USER=admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=postgres
DATABASE_URL=jdbc:postgresql://postgres:5432/user_db

# JWT Configuration
JWT_SECRET=your_jwt_secret_key_here
JWT_EXPIRATION=86400000

# RabbitMQ Configuration
RABBITMQ_USER=guest
RABBITMQ_PASSWORD=your_rabbitmq_password_here
RABBITMQ_HOST=rabbitmq
RABBITMQ_PORT=5672

# Service Ports
DISCOVERY_SERVER_PORT=8761
CONFIG_SERVER_PORT=8888
API_GATEWAY_PORT=8080
USER_SERVICE_PORT=8081
POST_SERVICE_PORT=8082
NOTIFICATION_SERVICE_PORT=8083
CHAT_SERVICE_PORT=8084
MEDIA_SERVICE_PORT=8085
ANALYTICS_SERVICE_PORT=8086

# Server URLs
CONFIG_SERVER_URL=http://localhost:8888
EUREKA_SERVICE_URL=http://discovery-server:8761/eureka/

# Frontend URLs
FRONTEND_URL_1=http://localhost:5173
FRONTEND_URL_2=http://localhost:5174
FRONTEND_URL_3=http://127.0.0.1:5173
FRONTEND_URL_4=http://127.0.0.1:5174

# Database Connection
DATABASE_USERNAME=admin
DATABASE_PASSWORD=your_secure_password_here

# Spring Profile
SPRING_PROFILES_ACTIVE=docker

# Timezone
TZ=Asia/Kolkata
